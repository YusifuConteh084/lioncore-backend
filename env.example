# ─────────────────────────────────────────────
# LionCore Technologies - Environment Config
# Copy this file to .env and fill in values
# NEVER commit .env to GitHub!
# ─────────────────────────────────────────────

# Flask
SECRET_KEY=lioncore-super-secret-key-change-this-in-production-2026
FLASK_ENV=development
FLASK_DEBUG=True

# Database (SQLite path — change to PostgreSQL URL for production)
DATABASE=database/lioncore.db

# Mail (optional — configure to send real emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=info@lioncoretech.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=info@lioncoretech.com

# Admin default credentials (change after first login!)
ADMIN_EMAIL=admin@lioncoretech.com
ADMIN_PASSWORD=LionCore@2026

# Frontend URL (for CORS in production)
FRONTEND_URL=https://www.lioncoretech.com
